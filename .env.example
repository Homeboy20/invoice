# Copy to .env and fill in before deploying.

# --- Database (required) ---
# PrintDesk stores everything in PostgreSQL. docker-compose.yml runs Postgres for you
# as the "db" service — just set the password below and DATABASE_URL is wired up
# automatically. Only override DATABASE_URL yourself if pointing at a Postgres you run
# elsewhere (e.g. a managed instance instead of the bundled container).
POSTGRES_PASSWORD=

# Signs session tokens — must be a long random secret, kept identical across restarts
# (rotating it logs every business out). Generate with: openssl rand -hex 32
JWT_SECRET=

# Port the server listens on inside the container.
PORT=4100

# The public URL this server is reachable at — used to build PayPal return/cancel links
# and the ClickPesa webhook callback URL. Must match your real domain in production
# (e.g. https://invoices.yourdomain.com).
SITE_URL=http://localhost:4100

# --- Admin panel (optional) ---
# Leave blank to disable /admin entirely. Set to enable the platform-wide business
# management panel (all tenants, revenue, plan overrides) at /admin/login.html.
ADMIN_PASSWORD=

# --- Billing (optional) ---
# Leave a gateway's variables blank to hide that payment button — PrintDesk runs fine
# with zero, one, or both configured. See server/README.md "Payment setup" for exact
# steps for each. Each successful payment (either gateway) buys 30 days of Premium —
# neither gateway auto-renews.

# PayPal (Orders API — REST, no SDK). From developer.paypal.com → your app's keys.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENVIRONMENT=sandbox
# set to "live" only once you're ready to accept real cards

# ClickPesa (Tanzania mobile money + cards). From your ClickPesa merchant dashboard.
CLICKPESA_API_KEY=
CLICKPESA_CLIENT_ID=
